#!/bin/sh
# Pre-commit hook — installed via: git config core.hooksPath .githooks
# Customise the variables below for your project.
set -e

# === PROJECT-SPECIFIC — edit these ===
BUILD_CMD="dotnet build --nologo -v q"
TEST_CMD="dotnet test --nologo --no-build --collect:\"XPlat Code Coverage\" --results-directory TestResults -v q"
COVERAGE_FLOOR=85
# =====================================

REPO_ROOT=$(git rev-parse --show-toplevel)

echo "── pre-commit checks ──"

# 0. Default branch check (warn once if on master)
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$CURRENT_BRANCH" = "master" ]; then
    echo "WARNING: Default branch should be 'main', not 'master'."
    echo "  Rename with: git branch -m master main && git push -u origin main"
    echo "  Then on GitHub: Settings → Branches → change default to main"
fi

# 1. Secrets detection
echo "[1/6] Checking for secrets..."
SECRETS_PATTERN='(password|secret|api[_-]?key|token|credential)\s*[:=]\s*["\x27][^"\x27]{8,}'
if git diff --cached --diff-filter=d -U0 | grep -iEq "$SECRETS_PATTERN"; then
    echo "ERROR: Possible secret detected in staged changes."
    echo "Run: git diff --cached | grep -iE '$SECRETS_PATTERN'"
    exit 1
fi

# 2. Fix CRLF → LF
echo "[2/6] Fixing line endings..."
STAGED=$(git diff --cached --name-only --diff-filter=ACM)
for file in $STAGED; do
    if [ -f "$file" ] && file "$file" | grep -q "CRLF"; then
        sed -i 's/\r$//' "$file"
        git add "$file"
        echo "  Fixed CRLF: $file"
    fi
done

# 3. Build check
echo "[3/6] Running build..."
if ! $BUILD_CMD 2>&1 | tail -3; then
    echo "ERROR: Build failed. Fix before committing."
    exit 1
fi

# 4. Run tests with coverage
echo "[4/6] Running tests with coverage..."
if ! eval $TEST_CMD 2>&1 | tail -3; then
    echo "ERROR: Tests failed. Fix before committing."
    exit 1
fi

# 5. Check coverage threshold (85% line + branch)
echo "[5/6] Checking coverage threshold..."
COVERAGE_FILE=$(find "$REPO_ROOT/TestResults" -name "coverage.cobertura.xml" -newer "$REPO_ROOT/.git/index" 2>/dev/null | head -1)
if [ -n "$COVERAGE_FILE" ]; then
    LINE_RATE=$(grep -oP 'line-rate="\K[^"]+' "$COVERAGE_FILE" | head -1)
    BRANCH_RATE=$(grep -oP 'branch-rate="\K[^"]+' "$COVERAGE_FILE" | head -1)
    LINE_PCT=$(echo "$LINE_RATE * 100" | bc -l 2>/dev/null | cut -d. -f1 || echo "0")
    BRANCH_PCT=$(echo "$BRANCH_RATE * 100" | bc -l 2>/dev/null | cut -d. -f1 || echo "0")
    echo "  Coverage: ${LINE_PCT}% line / ${BRANCH_PCT}% branch (floor: ${COVERAGE_FLOOR}%)"
    if [ "$LINE_PCT" -lt "$COVERAGE_FLOOR" ] 2>/dev/null; then
        echo "ERROR: Line coverage ${LINE_PCT}% is below ${COVERAGE_FLOOR}% floor. Write more tests."
        exit 1
    fi
    if [ "$BRANCH_PCT" -lt "$COVERAGE_FLOOR" ] 2>/dev/null; then
        echo "ERROR: Branch coverage ${BRANCH_PCT}% is below ${COVERAGE_FLOOR}% floor. Write more tests."
        exit 1
    fi
fi

# 6. Testing register sync
echo "[6/6] Checking testing register..."
TEST_FILES_CHANGED=$(git diff --cached --name-only | grep -ciE "(tests?/|\.test\.|\.spec\.|_test\.)" || true)
REGISTER_CHANGED=$(git diff --cached --name-only | grep -c "testing-register" || true)
if [ "$TEST_FILES_CHANGED" -gt 0 ] && [ "$REGISTER_CHANGED" -eq 0 ]; then
    echo "ERROR: Test files changed but .project/testing-register.md was not updated."
    echo "Update the testing register to reflect test changes."
    exit 1
fi

echo "── pre-commit passed ──"
